{
  "name": "cesteral-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Cesteral - AI-native programmatic advertising optimization platform with thirteen independent MCP servers",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:scripts": "vitest run --config vitest.config.scripts.ts",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test:conformance": "./scripts/conformance-test.sh",
    "test:conformance:ci": "./scripts/conformance-test.sh --ci",
    "generate:registry": "node scripts/generate-server-json.mjs",
    "generate:manifests": "node scripts/generate-manifests.mjs",
    "check:registry": "node scripts/generate-server-json.mjs --check",
    "sync:registry-tools": "node scripts/sync-registry-tools.mjs",
    "check:registry-tools": "node scripts/sync-registry-tools.mjs --check",
    "sync:registry-data": "node scripts/sync-registry-data.mjs",
    "check:registry-runtime": "node scripts/check-registry-runtime.mjs",
    "check:doc-tool-counts": "node scripts/check-doc-tool-counts.mjs"
  },
  "devDependencies": {
    "@cesteral/contract-hash": "workspace:*",
    "@cesteral/contract-schema": "workspace:*",
    "@modelcontextprotocol/conformance": "^0.1.15",
    "@modelcontextprotocol/sdk": "catalog:",
    "@types/node": "^20.17.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.38.0",
    "prettier": "3.6.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^1.6.0",
    "zod": "catalog:"
  },
  "packageManager": "pnpm@10.34.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  },
  "workspaces": [
    "packages/*"
  ]
}
