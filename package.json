{
  "name": "cesteral-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Cesteral - AI-native programmatic advertising optimization platform with five independent MCP servers",
  "license": "BSL-1.1",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test:conformance": "./scripts/conformance-test.sh",
    "test:conformance:ci": "./scripts/conformance-test.sh --ci"
  },
  "devDependencies": {
    "@modelcontextprotocol/conformance": "^0.1.15",
    "@types/node": "^20.17.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "packages/*"
  ]
}
