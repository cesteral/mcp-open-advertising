{
  "name": "@cesteral/contract-schema",
  "version": "1.2.0",
  "description": "Canonical governance-contract surface (annotations, manifest, dry-run, contractId) shared by Cesteral MCP servers and governance",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesteral/mcp-open-advertising.git",
    "directory": "packages/contract-schema"
  },
  "homepage": "https://github.com/cesteral/mcp-open-advertising#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "governance",
    "contract",
    "attestation",
    "schema"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0",
    "zod": "catalog:"
  }
}
