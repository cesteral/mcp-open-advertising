# Meta MCP Server Configuration

# Server
META_MCP_PORT=3005
META_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: meta-bearer (default), jwt, none
MCP_AUTH_MODE=meta-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Meta Marketing API
META_API_BASE_URL=https://graph.facebook.com/v25.0
META_API_VERSION=v25.0
META_RATE_LIMIT_PER_MINUTE=200

# Stdio mode credentials
META_ACCESS_TOKEN=your-access-token-here

# Optional: for token debug endpoint
# META_APP_ID=your-app-id
# META_APP_SECRET=your-app-secret

# Video upload safety (buffered proxy upload, not chunked streaming)
# META_VIDEO_UPLOAD_MAX_BUFFERED_BYTES=268435456

# Session Management
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=meta-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
