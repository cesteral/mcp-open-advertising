# Meta MCP Server Configuration

# Server
META_MCP_PORT=3005
META_MCP_HOST=127.0.0.1

# Auth mode: meta-bearer (default), jwt, none
MCP_AUTH_MODE=meta-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Meta Marketing API
META_API_BASE_URL=https://graph.facebook.com/v21.0
META_API_VERSION=v21.0
META_RATE_LIMIT_PER_MINUTE=200

# Stdio mode credentials
META_ACCESS_TOKEN=your-access-token-here

# Optional: for token debug endpoint
# META_APP_ID=your-app-id
# META_APP_SECRET=your-app-secret

# Logging
LOG_LEVEL=info

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=meta-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
