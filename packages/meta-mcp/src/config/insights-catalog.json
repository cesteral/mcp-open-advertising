{
  "description": "Static catalog of Meta Marketing API v24.0+ Insights fields, breakdowns, and action breakdowns. Seeded from https://developers.facebook.com/docs/marketing-api/insights/parameters. Keep in sync as the API evolves.",
  "levels": ["account", "campaign", "adset", "ad"],
  "metrics": {
    "delivery": ["impressions", "reach", "frequency", "spend", "cpm", "cpp"],
    "engagement": [
      "clicks",
      "unique_clicks",
      "cpc",
      "unique_cpc",
      "ctr",
      "unique_ctr",
      "inline_link_clicks",
      "inline_link_click_ctr",
      "cost_per_inline_link_click",
      "inline_post_engagement",
      "cost_per_inline_post_engagement"
    ],
    "video": [
      "video_play_actions",
      "video_thruplay_watched_actions",
      "video_p25_watched_actions",
      "video_p50_watched_actions",
      "video_p75_watched_actions",
      "video_p95_watched_actions",
      "video_p100_watched_actions",
      "video_avg_time_watched_actions",
      "cost_per_thruplay"
    ],
    "conversions": [
      "actions",
      "action_values",
      "unique_actions",
      "cost_per_action_type",
      "cost_per_unique_action_type",
      "conversions",
      "conversion_values",
      "cost_per_conversion",
      "purchase_roas",
      "website_purchase_roas"
    ],
    "attribution": ["attribution_setting", "mobile_app_purchase_roas"],
    "quality": ["quality_ranking", "engagement_rate_ranking", "conversion_rate_ranking"],
    "other": [
      "date_start",
      "date_stop",
      "account_id",
      "account_name",
      "account_currency",
      "campaign_id",
      "campaign_name",
      "adset_id",
      "adset_name",
      "ad_id",
      "ad_name",
      "objective",
      "optimization_goal",
      "buying_type"
    ]
  },
  "breakdowns": [
    "age",
    "gender",
    "country",
    "region",
    "dma",
    "impression_device",
    "publisher_platform",
    "platform_position",
    "device_platform",
    "product_id",
    "hourly_stats_aggregated_by_advertiser_time_zone",
    "hourly_stats_aggregated_by_audience_time_zone",
    "frequency_value"
  ],
  "actionBreakdowns": [
    "action_type",
    "action_target_id",
    "action_destination",
    "action_device",
    "action_video_sound",
