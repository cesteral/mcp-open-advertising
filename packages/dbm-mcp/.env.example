# DBM MCP Server Configuration (DV360 Reporting)

# Server
DBM_MCP_PORT=3001
DBM_MCP_HOST=127.0.0.1

# Auth mode: google-headers (default), jwt, none
MCP_AUTH_MODE=google-headers

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Google Cloud
# GCP_PROJECT_ID=your-project-id

# Stdio mode credentials (choose one)
# SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# SERVICE_ACCOUNT_JSON=base64-encoded-json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Report Polling (async Bid Manager reports)
# REPORT_CACHE_TTL_MS=300000
# REPORT_POLL_MAX_RETRIES=10
# REPORT_POLL_INITIAL_DELAY_MS=2000
# REPORT_POLL_MAX_DELAY_MS=60000
# REPORT_QUERY_RETRIES=3
# REPORT_RETRY_COOLDOWN_MS=60000

# Logging
LOG_LEVEL=info

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=dbm-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
