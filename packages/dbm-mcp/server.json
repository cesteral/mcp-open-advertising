{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.cesteral/dbm-mcp",
  "title": "Bid Manager MCP Server",
  "description": "Bid Manager reporting and query workflows for DV360 campaign performance analysis",
  "repository": {
    "url": "https://github.com/cesteral/cesteral-mcp-servers",
    "source": "github"
  },
  "version": "1.0.0",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://{host}/mcp",
      "variables": {
        "host": {
          "description": "Hostname of your deployed server instance (e.g., my-dbm-mcp-abc123.run.app)",
          "isRequired": true
        }
      }
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@cesteral/dbm-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
