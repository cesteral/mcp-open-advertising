{
  "name": "@bidshifter/dbm-mcp",
  "version": "1.0.0",
  "description": "DBM MCP Server - Generic cross-platform reporting and metrics",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "tsx scripts/generate-types.ts",
    "prebuild": "pnpm run generate",
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo src/generated",
    "dev:http": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "pnpm run generate && tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@bidshifter/platform-lib": "workspace:*",
    "@bidshifter/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "googleapis": "^166.0.0",
    "pino": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
