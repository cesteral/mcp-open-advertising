# Microsoft Ads MCP Server Configuration

# Server
MSADS_MCP_PORT=3013
MSADS_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: msads-bearer (default), jwt, none
MCP_AUTH_MODE=msads-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Microsoft Ads API
# MSADS_CAMPAIGN_API_BASE_URL=https://campaign.api.bingads.microsoft.com/CampaignManagement/v13
# MSADS_REPORTING_API_BASE_URL=https://reporting.api.bingads.microsoft.com/Reporting/v13
# MSADS_CUSTOMER_API_BASE_URL=https://clientcenter.api.bingads.microsoft.com/CustomerManagement/v13
MSADS_RATE_LIMIT_PER_MINUTE=10

# Stdio mode credentials
MSADS_ACCESS_TOKEN=your-access-token-here
MSADS_DEVELOPER_TOKEN=your-developer-token-here
MSADS_CUSTOMER_ID=your-customer-id-here
MSADS_ACCOUNT_ID=your-account-id-here

# Reporting poll configuration
# MSADS_REPORT_POLL_INTERVAL_MS=3000
# MSADS_REPORT_MAX_POLL_ATTEMPTS=30

# Session Management
# MCP_SESSION_MODE=auto
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=msads-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
