{
  "name": "@cesteral/sa360-mcp",
  "version": "1.0.0",
  "description": "Search Ads 360 MCP Server - Reporting and conversion upload via SA360 Reporting API v0 and legacy v2 API",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesteral/cesteral-mcp-servers.git",
    "directory": "packages/sa360-mcp"
  },
  "homepage": "https://github.com/cesteral/cesteral-mcp-servers#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "advertising",
    "search-ads-360",
    "sa360"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev:http": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cesteral/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pino": "^10.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
