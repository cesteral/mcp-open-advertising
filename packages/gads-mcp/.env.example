# Google Ads MCP Server Configuration

# Server
GADS_MCP_PORT=3004
GADS_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: gads-headers (default), jwt, none
MCP_AUTH_MODE=gads-headers

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Google Ads API
GADS_API_BASE_URL=https://googleads.googleapis.com/v23
GADS_RATE_LIMIT_PER_MINUTE=100

# Stdio mode credentials
GADS_DEVELOPER_TOKEN=your-developer-token
GADS_CLIENT_ID=your-client-id
GADS_CLIENT_SECRET=your-client-secret
GADS_REFRESH_TOKEN=your-refresh-token
# GADS_LOGIN_CUSTOMER_ID=your-mcc-customer-id

# Session Management
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=gads-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
