{
  "name": "@cesteral/snapchat-mcp",
  "display_name": "Snapchat Ads MCP Server",
  "description": "Snapchat Ads campaign management and reporting — CRUD, async reports, targeting, and audience estimates",
  "version": "1.0.0",
  "protocol_version": "2024-11-05",
  "transports": ["streamable-http", "stdio"],
  "tools": [
    "snapchat_list_entities",
    "snapchat_get_entity",
    "snapchat_create_entity",
    "snapchat_update_entity",
    "snapchat_delete_entity",
    "snapchat_list_ad_accounts",
    "snapchat_get_report",
    "snapchat_get_report_breakdowns",
    "snapchat_submit_report",
    "snapchat_check_report_status",
    "snapchat_download_report",
    "snapchat_bulk_update_status",
    "snapchat_bulk_create_entities",
    "snapchat_bulk_update_entities",
    "snapchat_adjust_bids",
    "snapchat_search_targeting",
    "snapchat_get_targeting_options",
    "snapchat_duplicate_entity",
    "snapchat_get_audience_estimate",
    "snapchat_get_ad_preview",
    "snapchat_validate_entity"
  ],
  "resources": [],
  "prompts": [
    "campaign_setup_workflow",
    "report_generation_workflow",
    "troubleshoot_entity",
    "tool_schema_exploration",
    "cross_platform_performance",
    "bulk_operations_workflow",
    "cross_platform_campaign_setup",
    "entity_update_workflow",
    "entity_duplication_workflow",
    "targeting_discovery_workflow",
    "snapchat_creative_setup_workflow"
  ],
  "auth": {
    "modes": ["snapchat-bearer", "jwt", "none"]
  },
  "repository": "https://github.com/cesteral/cesteral-mcp-servers",
  "license": "Apache-2.0",
  "tags": ["advertising", "snapchat", "campaign-management", "social", "video"]
}
