# Snapchat Ads MCP Server Configuration

# Server
SNAPCHAT_MCP_PORT=3009
SNAPCHAT_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: snapchat-bearer (default), jwt, none
MCP_AUTH_MODE=snapchat-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Snapchat API
SNAPCHAT_API_BASE_URL=https://adsapi.snapchat.com
SNAPCHAT_API_VERSION=v1
SNAPCHAT_RATE_LIMIT_PER_MINUTE=100

# Stdio mode credentials
SNAPCHAT_ACCESS_TOKEN=your-access-token-here
SNAPCHAT_AD_ACCOUNT_ID=your-ad-account-id

# Refresh token flow (recommended for production)
# SNAPCHAT_APP_ID=your-app-id
# SNAPCHAT_APP_SECRET=your-app-secret
# SNAPCHAT_REFRESH_TOKEN=your-refresh-token

# Report polling
# SNAPCHAT_REPORT_POLL_INTERVAL_MS=2000
# SNAPCHAT_REPORT_MAX_POLL_ATTEMPTS=30

# Session Management
# MCP_SESSION_MODE=auto
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=snapchat-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
