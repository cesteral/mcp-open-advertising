# Pinterest Ads MCP Server Configuration

# Server
PINTEREST_MCP_PORT=3011
PINTEREST_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: pinterest-bearer (default), jwt, none
MCP_AUTH_MODE=pinterest-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Pinterest API
PINTEREST_API_BASE_URL=https://api.pinterest.com
PINTEREST_API_VERSION=v5
PINTEREST_RATE_LIMIT_PER_MINUTE=100

# Stdio mode credentials
PINTEREST_ACCESS_TOKEN=your-access-token-here
PINTEREST_AD_ACCOUNT_ID=your-ad-account-id

# Refresh token flow (recommended for production)
# PINTEREST_APP_ID=your-app-id
# PINTEREST_APP_SECRET=your-app-secret
# PINTEREST_REFRESH_TOKEN=your-refresh-token

# Report polling
# PINTEREST_REPORT_POLL_INTERVAL_MS=2000
# PINTEREST_REPORT_MAX_POLL_ATTEMPTS=30

# Session Management
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=pinterest-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
