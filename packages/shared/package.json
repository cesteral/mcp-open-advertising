{
  "name": "@cesteral/shared",
  "version": "1.0.0",
  "description": "Shared infrastructure utilities and authentication for Cesteral MCP servers",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesteral/cesteral-mcp-servers.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/cesteral/cesteral-mcp-servers#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "advertising",
    "shared",
    "utilities"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google-cloud/opentelemetry-cloud-monitoring-exporter": "^0.20.0",
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^2.0.0",
    "@hono/mcp": "^0.2.3",
    "@hono/node-server": "^1.19.9",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.9",
    "jose": "^6.1.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
