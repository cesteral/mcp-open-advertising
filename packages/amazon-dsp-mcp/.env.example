# Amazon DSP Ads MCP Server Configuration

# Server
AMAZON_DSP_MCP_PORT=3013
AMAZON_DSP_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: amazon-dsp-bearer (default), jwt, none
MCP_AUTH_MODE=amazon-dsp-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Amazon DSP API
AMAZON_DSP_API_BASE_URL=https://advertising-api.amazon.com
AMAZON_DSP_API_VERSION=dsp
# Amazon DSP enforces tight per-LwA-app rolling-window quotas on /dsp/orders,
# /dsp/lineItems, /dsp/creatives (well below 100/min in practice). The client
# default is 10 to stay safely under; raise only if you've measured headroom
# against your own app and confirmed the quota window. Hitting 429 burns the
# window further — Amazon does not send Retry-After.
AMAZON_DSP_RATE_LIMIT_PER_MINUTE=10

# Profile ID — required for both auth flows below. Retrieve via Amazon's
# /v2/profiles endpoint (see "Step 3: Retrieve a Profile ID" in
# https://advertising.amazon.com/API/docs/en-us/guides/get-started/retrieve-profiles).
AMAZON_DSP_PROFILE_ID=your-profile-id

# === Flow A: LwA refresh-token (recommended) ============================
# Access tokens are minted on demand from the refresh token via
# https://api.amazon.com/auth/o2/token and auto-refreshed before the 60-min
# expiry. Refresh tokens do not expire unless revoked.
# To obtain a refresh token: run Amazon's Postman collection
# (https://github.com/amzn/ads-advanced-tools-docs) or follow steps 1-2 at
# https://advertising.amazon.com/API/docs/en-us/guides/get-started/overview
AMAZON_DSP_APP_ID=your-lwa-client-id
AMAZON_DSP_APP_SECRET=your-lwa-client-secret
AMAZON_DSP_REFRESH_TOKEN=your-lwa-refresh-token

# === Flow B: Static access token (fallback, expires in 60 minutes) =======
# Useful for short-lived CI runs. Server will start returning 401 after
# 60 minutes — re-mint the token via the LwA token endpoint to recover.
# AMAZON_DSP_ACCESS_TOKEN=Atza|...
# AMAZON_DSP_CLIENT_ID=your-lwa-client-id   # required when using static token

# Report polling
# AMAZON_DSP_REPORT_POLL_INTERVAL_MS=2000
# AMAZON_DSP_REPORT_MAX_POLL_ATTEMPTS=30

# Session Management
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=amazon-dsp-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
