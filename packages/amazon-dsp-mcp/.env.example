# Amazon DSP Ads MCP Server Configuration

# Server
AMAZON_DSP_MCP_PORT=3013
AMAZON_DSP_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: amazon-bearer (default), jwt, none
MCP_AUTH_MODE=amazon-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# Amazon DSP API
AMAZON_DSP_API_BASE_URL=https://advertising-api.amazon.com
AMAZON_DSP_API_VERSION=dsp
AMAZON_DSP_RATE_LIMIT_PER_MINUTE=100

# Stdio mode credentials
AMAZON_DSP_ACCESS_TOKEN=your-access-token-here
AMAZON_DSP_PROFILE_ID=your-profile-id
AMAZON_DSP_CLIENT_ID=your-client-id

# Refresh token flow (recommended for production)
# AMAZON_DSP_APP_ID=your-app-id
# AMAZON_DSP_APP_SECRET=your-app-secret
# AMAZON_DSP_REFRESH_TOKEN=your-refresh-token

# Report polling
# AMAZON_DSP_REPORT_POLL_INTERVAL_MS=2000
# AMAZON_DSP_REPORT_MAX_POLL_ATTEMPTS=30

# Session Management
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=amazon-dsp-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
