# TikTok Ads MCP Server Configuration

# Server
TIKTOK_MCP_PORT=3007
TIKTOK_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: tiktok-bearer (default), jwt, none
MCP_AUTH_MODE=tiktok-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# TikTok API
TIKTOK_API_BASE_URL=https://business-api.tiktok.com
TIKTOK_API_VERSION=v1.3
TIKTOK_RATE_LIMIT_PER_MINUTE=100

# Stdio mode credentials
TIKTOK_ACCESS_TOKEN=your-access-token-here
TIKTOK_ADVERTISER_ID=your-advertiser-id

# Refresh token flow (recommended for production)
# TIKTOK_APP_ID=your-app-id
# TIKTOK_APP_SECRET=your-app-secret
# TIKTOK_REFRESH_TOKEN=your-refresh-token

# Report polling
# TIKTOK_REPORT_POLL_INTERVAL_MS=2000
# TIKTOK_REPORT_MAX_POLL_ATTEMPTS=30

# Session Management
# MCP_SESSION_MODE=auto
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=tiktok-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
