{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.cesteral/dv360-mcp",
  "title": "DV360 MCP Server",
  "description": "DV360 campaign management — writes, targeting, custom bidding, previews, and media uploads",
  "repository": {
    "url": "https://github.com/cesteral/mcp-open-advertising",
    "source": "github"
  },
  "version": "1.3.0",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://{host}/dv360-mcp/mcp",
      "variables": {
        "host": {
          "description": "Hostname of your deployed server instance (e.g., my-dv360-mcp-abc123.run.app)",
          "isRequired": true
        }
      }
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@cesteral/dv360-mcp",
      "version": "1.3.0",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
