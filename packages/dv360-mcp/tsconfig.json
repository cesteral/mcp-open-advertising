{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    }
  },
  "references": [
    { "path": "../shared" },
    { "path": "../platform-lib" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "src/examples"]
}
