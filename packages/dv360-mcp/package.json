{
  "name": "@cesteral/dv360-mcp",
  "version": "1.0.0",
  "description": "DV360 MCP Server - Campaign entity management and configuration",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesteral/cesteral-mcp-servers.git",
    "directory": "packages/dv360-mcp"
  },
  "homepage": "https://github.com/cesteral/cesteral-mcp-servers#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "advertising",
    "dv360",
    "display-video-360"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "prebuild": "pnpm run generate:schemas",
    "clean": "rm -rf dist *.tsbuildinfo .tmp-specs",
    "dev:http": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate:schemas": "tsx scripts/generate-schemas.ts",
    "generate:schemas:watch": "tsx watch scripts/generate-schemas.ts"
  },
  "dependencies": {
    "@cesteral/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pino": "^10.1.0",
    "zod": "3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.6",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.1.1",
    "openapi-typescript": "^7.10.1",
    "openapi-zod-client": "^1.18.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
