# =============================================================================
# dv360-mcp Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# Required variables are marked with [REQUIRED]
# Optional variables show their default values

# =============================================================================
# Service Configuration
# =============================================================================

# Service identifier used in logging and telemetry
SERVICE_NAME=dv360-mcp

# HTTP server configuration
DV360_MCP_PORT=3002
DV360_MCP_HOST=0.0.0.0

# Environment mode (affects logging, error handling, auth enforcement)
NODE_ENV=development  # Options: development | production | test

# =============================================================================
# DV360 API Authentication [REQUIRED]
# =============================================================================

# Google Cloud Service Account credentials for DV360 API access
# Choose ONE of the following options:

# OPTION 1: Path to service account JSON file (RECOMMENDED for local development)
# This is the most secure and convenient option for local development
# Example: /Users/yourname/.config/gcloud/dv360-service-account.json
DV360_SERVICE_ACCOUNT_FILE=

# OPTION 2: Base64-encoded service account JSON (for CI/CD, containers)
# To encode: cat service-account.json | base64
DV360_SERVICE_ACCOUNT_JSON=

# OPTION 3: GCP Secret Manager secret ID (for production Cloud Run)
# Example: projects/123456789/secrets/dv360-service-account/versions/latest
SERVICE_ACCOUNT_SECRET_ID=

# NOTE: You must provide ONE of the above options
# See docs/SERVICE_ACCOUNT_SETUP.md for detailed setup instructions

# =============================================================================
# MCP Client Authentication
# =============================================================================

# Authentication mode for MCP clients connecting to this server
MCP_AUTH_MODE=none  # Options: none | jwt | oauth

# JWT secret key (required if MCP_AUTH_MODE=jwt)
# Generate with: openssl rand -base64 32
MCP_AUTH_SECRET_KEY=

# Legacy JWT secret (for backward compatibility)
JWT_SECRET=

# =============================================================================
# Session Management
# =============================================================================

# Session mode for MCP connections

# Stateful session timeout (milliseconds)
MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000  # Default: 1 hour

# =============================================================================
# CORS Configuration
# =============================================================================

# Comma-separated list of allowed origins for CORS
# Example: https://app.example.com,https://admin.example.com
MCP_ALLOWED_ORIGINS=

# =============================================================================
# DV360 API Configuration
# =============================================================================

# DV360 API base URL (typically no need to change)
DV360_API_BASE_URL=https://displayvideo.googleapis.com/v4

# Rate limiting for DV360 API requests (per advertiser)
DV360_RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# Logging Configuration
# =============================================================================

# General log level
LOG_LEVEL=info  # Options: debug | info | notice | warning | error

# MCP-specific log level
MCP_LOG_LEVEL=debug  # Options: debug | info | notice | warning | error

# =============================================================================
# OpenTelemetry (Optional)
# =============================================================================

# Enable OpenTelemetry instrumentation
OTEL_ENABLED=false

# Service name for telemetry (defaults to SERVICE_NAME if not set)
OTEL_SERVICE_NAME=dv360-mcp

# OTLP exporter endpoints (optional - only needed if using custom collectors)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=

# =============================================================================
# Production Checklist
# =============================================================================
# Before deploying to production, ensure:
# ✓ NODE_ENV=production
# ✓ Service account configured (use SERVICE_ACCOUNT_SECRET_ID for Cloud Run)
# ✓ MCP_AUTH_MODE=jwt and MCP_AUTH_SECRET_KEY set
# ✓ LOG_LEVEL set appropriately (info or warning)
# ✓ CORS origins configured if needed
# ✓ OpenTelemetry configured for monitoring
#
# Local Development Checklist:
# ✓ DV360_SERVICE_ACCOUNT_FILE pointing to your service account JSON
# ✓ NODE_ENV=development
# ✓ MCP_AUTH_MODE=none (for testing)
# ✓ Service account has DV360 API access
