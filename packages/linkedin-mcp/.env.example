# LinkedIn Ads MCP Server Configuration

# Server
LINKEDIN_MCP_PORT=3006
LINKEDIN_MCP_HOST=127.0.0.1
NODE_ENV=development

# Auth mode: linkedin-bearer (default), jwt, none
MCP_AUTH_MODE=linkedin-bearer

# JWT auth (only for jwt mode)
# MCP_AUTH_SECRET_KEY=your-secret-key

# LinkedIn API
LINKEDIN_API_BASE_URL=https://api.linkedin.com
LINKEDIN_API_VERSION=202501
LINKEDIN_RATE_LIMIT_PER_MINUTE=100

# Stdio mode credentials
LINKEDIN_ACCESS_TOKEN=your-access-token-here

# Refresh token flow (recommended for production)
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret
# LINKEDIN_REFRESH_TOKEN=your-refresh-token

# Session Management
# MCP_SESSION_MODE=auto
# MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000

# CORS
# MCP_ALLOWED_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info
# MCP_LOG_LEVEL=debug

# OpenTelemetry (optional)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=linkedin-mcp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# GCS Persistence (optional)
# GCS_BUCKET_NAME=your-bucket-name
