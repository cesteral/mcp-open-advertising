{
  "version": "1.4.0",
  "architecture": {
    "accessPatterns": [
      "direct-client-orchestration",
      "optional-server-side-orchestration"
    ],
    "resourceNamespacingPolicy": {
      "status": "recommended-compatible-rollout",
      "currentUrisRemainValid": true,
      "preferredUriExamples": [
        "dv360:entity-schema://{entityType}",
        "dv360:entity-fields://{entityType}",
        "dv360:entity-examples://{entityType}",
        "ttd:entity-schema://{entityType}",
        "ttd:entity-examples://{entityType}"
      ]
    }
  },
  "workflowIds": [
    "mcp.explore.tools_and_schemas",
    "mcp.execute.dv360_entity_update",
    "mcp.execute.dv360_budget_reallocation",
    "mcp.execute.ttd_entity_update",
    "mcp.execute.ttd_campaign_setup",
    "mcp.execute.ttd_report",
    "mcp.troubleshoot.ttd_entity",
    "mcp.execute.dbm_custom_query",
    "mcp.execute.gads_query",
    "mcp.execute.gads_entity_management",
    "mcp.execute.gads_bulk_operations",
    "mcp.troubleshoot.delivery",
    "mcp.improve.learnings_review",
    "mcp.execute.meta_entity_update",
    "mcp.execute.meta_campaign_setup",
    "mcp.execute.meta_insights",
    "mcp.execute.meta_bulk_operations",
    "mcp.troubleshoot.meta_entity"
  ],
  "workflows": {
    "mcp.explore.tools_and_schemas": {
      "description": "Discover tools, prompts, and resources with minimal context usage.",
      "prompts": [
        {
          "server": "dbm-mcp",
          "name": "tool_schema_exploration_workflow"
        },
        {
          "server": "gads-mcp",
          "name": "gads_tool_schema_exploration"
        },
        {
          "server": "ttd-mcp",
          "name": "ttd_tool_schema_exploration"
        },
        {
          "server": "meta-mcp",
          "name": "meta_tool_schema_exploration"
        }
      ],
      "resources": [
        "filter-types://category/{slug}",
        "metric-types://category/{slug}",
        "report-types://all",
        "compatibility-rules://all",
        "entity-schema://{entityType}",
        "entity-fields://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "Scope",
        "SelectedResources",
        "NextToolCall"
      ]
    },
    "mcp.execute.dv360_entity_update": {
      "description": "Perform safe schema-first DV360 entity updates with updateMask discipline.",
      "prompts": [
        {
          "server": "dv360-mcp",
          "name": "entity_update_execution_workflow"
        }
      ],
      "resources": [
        "entity-schema://{entityType}",
        "entity-fields://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "ChangePlan",
        "UpdateMask",
        "VerificationResult"
      ]
    },
    "mcp.execute.dv360_budget_reallocation": {
      "description": "Analyze and reallocate budgets across DV360 insertion orders and line items with safe execution.",
      "prompts": [
        {
          "server": "dv360-mcp",
          "name": "budget_reallocation_workflow"
        }
      ],
      "resources": [
        "entity-schema://{entityType}",
        "entity-fields://{entityType}"
      ],
      "requiredOutputSections": [
        "AnalysisSummary",
        "ReallocationPlan",
        "ExecutionSummary"
      ]
    },
    "mcp.execute.ttd_entity_update": {
      "description": "Perform safe The Trade Desk entity updates with schema-first validation and minimal payload changes.",
      "prompts": [
        {
          "server": "ttd-mcp",
          "name": "ttd_campaign_setup_workflow"
        }
      ],
      "resources": [
        "entity-schema://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "ChangePlan",
        "PayloadDiff",
        "VerificationResult"
      ]
    },
    "mcp.execute.ttd_campaign_setup": {
      "description": "Create complete TTD campaign structures (Campaign → Ad Group → Ad → Creative) with schema-first validation.",
      "prompts": [
        {
          "server": "ttd-mcp",
          "name": "ttd_campaign_setup_workflow"
        }
      ],
      "resources": [
        "entity-schema://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "ChangePlan",
        "PayloadDiff",
        "VerificationResult"
      ]
    },
    "mcp.execute.ttd_report": {
      "description": "Build and execute TTD MyReports V3 async reports with dimension/metric validation.",
      "prompts": [
        {
          "server": "ttd-mcp",
          "name": "ttd_report_generation_workflow"
        }
      ],
      "resources": [],
      "requiredOutputSections": [
        "QuerySpec",
        "ValidationChecks",
        "ExecutionSummary"
      ]
    },
    "mcp.troubleshoot.ttd_entity": {
      "description": "Diagnose and remediate TTD entity issues using schema inspection and targeted updates.",
      "prompts": [
        {
          "server": "ttd-mcp",
          "name": "ttd_troubleshoot_entity"
        }
      ],
      "resources": [
        "entity-schema://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "Symptoms",
        "RootCauseHypothesis",
        "FixAndMonitorPlan"
      ]
    },
    "mcp.execute.dbm_custom_query": {
      "description": "Build and run custom Bid Manager queries with compatibility validation.",
      "prompts": [
        {
          "server": "dbm-mcp",
          "name": "custom_query_workflow"
        }
      ],
      "resources": [
        "report-types://all",
        "filter-types://category/{slug}",
        "metric-types://category/{slug}",
        "query-examples://all",
        "compatibility-rules://all"
      ],
      "requiredOutputSections": [
        "QuerySpec",
        "ValidationChecks",
        "ExecutionSummary"
      ]
    },
    "mcp.execute.gads_query": {
      "description": "Build and execute GAQL-based Google Ads reporting queries with schema-aware validation.",
      "prompts": [
        {
          "server": "gads-mcp",
          "name": "gads_tool_schema_exploration"
        },
        {
          "server": "gads-mcp",
          "name": "gaql_reporting_workflow"
        }
      ],
      "resources": [
        "gaql-reference://syntax",
        "entity-schema://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "QuerySpec",
        "ValidationChecks",
        "ExecutionSummary"
      ]
    },
    "mcp.execute.gads_entity_management": {
      "description": "Perform safe Google Ads entity CRUD operations with schema-first validation and targeted updates.",
      "prompts": [
        {
          "server": "gads-mcp",
          "name": "gads_campaign_setup_workflow"
        },
        {
          "server": "gads-mcp",
          "name": "gads_troubleshoot_entity"
        }
      ],
      "resources": [
        "entity-schema://{entityType}",
        "entity-examples://{entityType}",
        "entity-hierarchy://gads"
      ],
      "requiredOutputSections": [
        "ChangePlan",
        "PayloadDiff",
        "VerificationResult"
      ]
    },
    "mcp.execute.gads_bulk_operations": {
      "description": "Execute batch Google Ads mutate and status operations with controlled payload sizing and verification.",
      "prompts": [
        {
          "server": "gads-mcp",
          "name": "gads_campaign_setup_workflow"
        }
      ],
      "resources": [
        "entity-schema://{entityType}",
        "entity-examples://{entityType}",
        "entity-hierarchy://gads"
      ],
      "requiredOutputSections": [
        "BatchPlan",
        "SafetyChecks",
        "ExecutionSummary"
      ]
    },
    "mcp.troubleshoot.delivery": {
      "description": "Diagnose and remediate underdelivery using reporting and management servers.",
      "prompts": [
        {
          "server": "dv360-mcp",
          "name": "troubleshoot_underdelivery"
        },
        {
          "server": "dbm-mcp",
          "name": "troubleshoot_report"
        }
      ],
      "resources": [
        "compatibility-rules://all",
        "entity-schema://{entityType}",
        "entity-fields://{entityType}",
        "targeting-types://"
      ],
      "requiredOutputSections": [
        "Symptoms",
        "RootCauseHypothesis",
        "FixAndMonitorPlan"
      ]
    },
    "mcp.execute.meta_entity_update": {
      "description": "Perform safe Meta Ads entity mutations (create, update, delete) with schema-first validation.",
      "prompts": [
        {
          "server": "meta-mcp",
          "name": "meta_campaign_setup_workflow"
        }
      ],
      "resources": [
        "entity-hierarchy://all",
        "entity-schema://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "ChangePlan",
        "PayloadDiff",
        "VerificationResult"
      ]
    },
    "mcp.execute.meta_campaign_setup": {
      "description": "Create complete Meta Ads campaign structures (Campaign → Ad Set → Creative → Ad) with creation-order enforcement.",
      "prompts": [
        {
          "server": "meta-mcp",
          "name": "meta_campaign_setup_workflow"
        }
      ],
      "resources": [
        "entity-hierarchy://all",
        "entity-schema://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "ChangePlan",
        "PayloadDiff",
        "VerificationResult"
      ]
    },
    "mcp.execute.meta_insights": {
      "description": "Query Meta Ads Insights API for performance metrics with breakdowns and attribution windows.",
      "prompts": [
        {
          "server": "meta-mcp",
          "name": "meta_insights_reporting_workflow"
        }
      ],
      "resources": [
        "insights-reference://all"
      ],
      "requiredOutputSections": [
        "QuerySpec",
        "ValidationChecks",
        "ExecutionSummary"
      ]
    },
    "mcp.execute.meta_bulk_operations": {
      "description": "Execute batch Meta Ads operations (bulk create, bulk status update) with controlled concurrency.",
      "prompts": [
        {
          "server": "meta-mcp",
          "name": "meta_campaign_setup_workflow"
        }
      ],
      "resources": [
        "entity-hierarchy://all",
        "entity-schema://{entityType}"
      ],
      "requiredOutputSections": [
        "BatchPlan",
        "SafetyChecks",
        "ExecutionSummary"
      ]
    },
    "mcp.troubleshoot.meta_entity": {
      "description": "Diagnose and remediate Meta Ads entity issues using API inspection and targeted fixes.",
      "prompts": [
        {
          "server": "meta-mcp",
          "name": "meta_troubleshoot_entity"
        }
      ],
      "resources": [
        "entity-hierarchy://all",
        "entity-schema://{entityType}",
        "entity-examples://{entityType}"
      ],
      "requiredOutputSections": [
        "Symptoms",
        "RootCauseHypothesis",
        "FixAndMonitorPlan"
      ]
    },
    "mcp.improve.learnings_review": {
      "description": "Review interaction logs and learnings tree to propose codebase improvements.",
      "prompts": [],
      "resources": [
        "learnings://agent-behaviors",
        "learnings://workflows",
        "learnings://platforms/{platform}",
        "learnings://all"
      ],
      "requiredOutputSections": [
        "LogAnalysis",
        "LearningsGaps",
        "Proposals",
        "Evidence"
      ]
    }
  },
  "adapterRules": {
    "maxSkillLines": 200,
    "mustReferenceWorkflowId": true,
    "mustNotDuplicateLargeSchemas": true,
    "requirePackageWorkflowMapping": true,
    "canonicalSourceDir": "skills/canonical",
    "providerRegistry": "skills/providers.json"
  },
  "providers": {
    "cursor": {
      "tier": "active",
      "format": "skill-per-directory",
      "status": "generated"
    },
    "codex": {
      "tier": "active",
      "format": "skill-per-directory",
      "status": "generated"
    },
    "copilot": {
      "tier": "active",
      "format": "single-concatenated",
      "status": "generated"
    },
    "windsurf": {
      "tier": "active",
      "format": "file-per-skill",
      "status": "generated"
    },
    "cline": {
      "tier": "active",
      "format": "file-per-skill",
      "status": "generated"
    },
    "continue": {
      "tier": "active",
      "format": "file-per-skill",
      "status": "generated"
    }
  },
  "platformPackages": {
    "dbm-mcp": {
      "platform": "dv360-reporting",
      "requiredWorkflowIds": [
        "mcp.explore.tools_and_schemas",
        "mcp.execute.dbm_custom_query",
        "mcp.troubleshoot.delivery"
      ]
    },
    "dv360-mcp": {
      "platform": "dv360-management",
      "requiredWorkflowIds": [
        "mcp.execute.dv360_entity_update",
        "mcp.execute.dv360_budget_reallocation",
        "mcp.troubleshoot.delivery"
      ]
    },
    "ttd-mcp": {
      "platform": "ttd",
      "requiredWorkflowIds": [
        "mcp.explore.tools_and_schemas",
        "mcp.execute.ttd_entity_update",
        "mcp.execute.ttd_campaign_setup",
        "mcp.execute.ttd_report",
        "mcp.troubleshoot.ttd_entity"
      ]
    },
    "gads-mcp": {
      "platform": "google-ads",
      "requiredWorkflowIds": [
        "mcp.explore.tools_and_schemas",
        "mcp.execute.gads_query",
        "mcp.execute.gads_entity_management",
        "mcp.execute.gads_bulk_operations"
      ]
    },
    "meta-mcp": {
      "platform": "meta",
      "requiredWorkflowIds": [
        "mcp.explore.tools_and_schemas",
        "mcp.execute.meta_entity_update",
        "mcp.execute.meta_campaign_setup",
        "mcp.execute.meta_insights",
        "mcp.execute.meta_bulk_operations",
        "mcp.troubleshoot.meta_entity"
      ]
    }
  }
}
