# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Environment variables
.env
.env.*
!.env.example

# Build outputs
dist/
build/
*.tsbuildinfo

# Testing
coverage/
.nyc_output/
*.lcov

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Runtime interaction logs (generated by InteractionLogger)
**/data/interactions/

# Temporary files
tmp/
temp/
*.tmp

# Google Cloud
.gcloudignore
service-account-key.json
*-key.json

# Terraform (tracked in terraform/.gitignore, but adding common ones here too)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Docker
.dockerignore

# Worktrees
.worktrees/

# Conformance test results
.conformance-results/

# Turbo
.turbo/

# Package manager
.pnpm-store/
.yarn/

# Credentials
*.key
*.pem
*.crt
credentials.json

# DV360 MCP Schema Extraction
# Temporary specs (fetched at build time)
.tmp-specs/
*.discovery.json

# DO NOT ignore generated schemas (these are committed)
# src/generated/schemas/

# Amazon DSP MCP — vendored OpenAPI spec (locally placed, not tracked)
# See packages/amazon-dsp-mcp/docs/README.md for how to obtain a copy.
packages/amazon-dsp-mcp/docs/openapi.json

# Terraform local config (use *.example files as templates)
terraform/*.tfvars
terraform/backend-*.conf

# Live-test outputs (per-server, runtime artifacts)
packages/*/tests/live/last-run.json

# Sibling worktrees created by Claude Code (each has its own branch)
.claude/worktrees/
