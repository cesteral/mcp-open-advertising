# Production environment configuration

# Project configuration
project_id  = "YOUR_GCP_PROJECT_PROD"
region      = "europe-west2"
environment = "prod"

# Container images (update after first build)
dbm_mcp_image        = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/dbm-mcp:latest"
dv360_mcp_image      = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/dv360-mcp:latest"
ttd_mcp_image        = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/ttd-mcp:latest"
gads_mcp_image       = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/gads-mcp:latest"
meta_mcp_image       = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/meta-mcp:latest"
linkedin_mcp_image   = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/linkedin-mcp:latest"
tiktok_mcp_image     = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/tiktok-mcp:latest"
cm360_mcp_image      = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/cm360-mcp:latest"
sa360_mcp_image      = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/sa360-mcp:latest"
pinterest_mcp_image  = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/pinterest-mcp:latest"
snapchat_mcp_image   = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/snapchat-mcp:latest"
amazon_dsp_mcp_image = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/amazon-dsp-mcp:latest"
msads_mcp_image      = "europe-west2-docker.pkg.dev/YOUR_GCP_PROJECT_PROD/cesteral/msads-mcp:latest"

# Networking
create_vpc             = true
serverless_subnet_cidr = "10.8.0.0/28"

# VPC connector - robust for production
connector_machine_type   = "e2-micro"
connector_min_instances  = 2
connector_max_instances  = 10
connector_min_throughput = 300
connector_max_throughput = 1000

# Cloud NAT
enable_nat_logging                  = true
nat_log_filter                      = "ERRORS_ONLY"
nat_min_ports_per_vm                = 64
enable_endpoint_independent_mapping = true # Better for production

# Cloud Run - production scaling
min_instances         = 1   # Always keep 1 warm
max_instances         = 10  # Scale up to 10 for peak loads
cpu_limit             = "2" # More CPU for production
memory_limit          = "1Gi"
cpu_always_allocated  = true # Faster response times
allow_unauthenticated = false

# MCP Server configuration
log_level              = "info" # Production logging level
enable_gcs_persistence = false
gcs_bucket_name        = "YOUR_GCP_PROJECT_PROD-mcp-persistence" # Enable when ready

# Artifact Registry
artifact_registry_repo_name = "YOUR_REGISTRY"

# Monitoring
monitoring_notification_email = "your-email@example.com"

# Per-service resource overrides (heavy reporting server gets more resources)
service_resource_overrides = {
  "dbm-mcp" = {
    cpu_limit     = "2"
    memory_limit  = "1Gi"
    max_instances = 10
  }
}
