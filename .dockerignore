# Dependencies — installed fresh inside the image (deps stage). Never ship the
# host's node_modules into the build context: it bloats the context AND overlays
# host-arch (e.g. darwin-arm64) native binaries onto the alpine-linux image.
node_modules
**/node_modules

# Build outputs — regenerated by `pnpm run build` in the builder stage.
dist
**/dist
.turbo
**/.turbo
*.tsbuildinfo
**/*.tsbuildinfo
packages/*/.tmp-specs

# VCS / worktrees
.git
.worktrees

# Terraform local state + secrets — must never enter an image build context.
**/.terraform
**/*.tfstate
**/*.tfstate.*
**/*.tfvars
terraform/backend-*.conf

# Local env / editor / OS noise
.env
**/.env
.DS_Store
**/.DS_Store
*.log
coverage
**/coverage
.vscode
.idea
