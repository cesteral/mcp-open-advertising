# Environment (dev, staging, prod)
NODE_ENV=development

# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=europe-west2

# Cloud Storage Configuration
# Used for persisting data on Cloud Run.
# Uses Application Default Credentials (ADC) — no explicit key needed on Cloud Run.
GCS_BUCKET_NAME=cesteral-storage

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_ISSUER=cesteral-mcp
MCP_RESOURCE_URI=cesteral-services

# MCP Server Configuration
# dbm-mcp (Reporting Server)
DBM_MCP_PORT=3001
DBM_MCP_HOST=0.0.0.0

# dv360-mcp (Management Server)
DV360_MCP_PORT=3002
DV360_MCP_HOST=0.0.0.0

# ttd-mcp (The Trade Desk Server)
TTD_MCP_PORT=3003
TTD_MCP_HOST=0.0.0.0

# gads-mcp (Google Ads Server)
GADS_MCP_PORT=3004
GADS_MCP_HOST=0.0.0.0

# meta-mcp (Meta Ads Server)
META_MCP_PORT=3005
META_MCP_HOST=0.0.0.0

# linkedin-mcp (LinkedIn Ads Server)
LINKEDIN_MCP_PORT=3006
LINKEDIN_MCP_HOST=0.0.0.0

# tiktok-mcp (TikTok Ads Server)
TIKTOK_MCP_PORT=3007
TIKTOK_MCP_HOST=0.0.0.0

# cm360-mcp (Campaign Manager 360 Server)
CM360_MCP_PORT=3008
CM360_MCP_HOST=0.0.0.0

# snapchat-mcp (Snapchat Ads Server)
SNAPCHAT_MCP_PORT=3009
SNAPCHAT_MCP_HOST=0.0.0.0

# sa360-mcp (Search Ads 360 Server)
SA360_MCP_PORT=3010
SA360_MCP_HOST=0.0.0.0

# pinterest-mcp (Pinterest Ads Server)
PINTEREST_MCP_PORT=3011
PINTEREST_MCP_HOST=0.0.0.0

# amazon-dsp-mcp (Amazon DSP Server)
AMAZON_DSP_MCP_PORT=3012
AMAZON_DSP_MCP_HOST=0.0.0.0

# msads-mcp (Microsoft Advertising Server)
MSADS_MCP_PORT=3013
MSADS_MCP_HOST=0.0.0.0

# DV360 API Configuration
DV360_API_BASE_URL=https://displayvideo.googleapis.com/v4
DV360_SERVICE_ACCOUNT_JSON=                  # REQUIRED: Service account JSON (base64 or file path)
DV360_RATE_LIMIT_PER_MINUTE=60
SERVICE_ACCOUNT_SECRET_ID=                   # Optional: GCP Secret Manager secret ID

# MCP Session Management
MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000      # 1 hour
MCP_ALLOWED_ORIGINS=*                        # CSV of allowed origins

# MCP Authentication
# Each server accepts a platform-specific mode plus `jwt` and `none`:
#   dbm/dv360/cm360: google-headers | jwt | none
#   gads:            gads-headers | jwt | none
#   ttd:             ttd-token (aka ttd-headers) | jwt | none
#   meta:            meta-bearer | jwt | none
#   linkedin:        linkedin-bearer | jwt | none
#   tiktok:          tiktok-bearer | jwt | none
#   sa360:           sa360-headers | jwt | none
#   pinterest:       pinterest-bearer | jwt | none
#   snapchat:        snapchat-bearer | jwt | none
#   amazon-dsp:      amazon-dsp-bearer | jwt | none
#   msads:           msads-bearer | jwt | none
MCP_AUTH_MODE=none
MCP_AUTH_SECRET_KEY=                         # Required if MCP_AUTH_MODE=jwt (32+ chars)
MCP_LOG_LEVEL=debug                          # debug | info | notice | warning | error

# TTD API Configuration
TTD_API_TOKEN=                               # REQUIRED for TTD stdio mode: pre-generated user partner token (also accepted via TTD-Auth header in HTTP mode)

# Google Ads API Configuration
GADS_DEVELOPER_TOKEN=                        # REQUIRED: Google Ads developer token
GADS_CLIENT_ID=                              # REQUIRED: OAuth2 client ID
GADS_CLIENT_SECRET=                          # REQUIRED: OAuth2 client secret
GADS_REFRESH_TOKEN=                          # REQUIRED: OAuth2 refresh token
GADS_LOGIN_CUSTOMER_ID=                      # Optional: Manager account customer ID (no dashes)
GADS_API_BASE_URL=https://googleads.googleapis.com/v23
GADS_RATE_LIMIT_PER_MINUTE=100

# Meta API Configuration
META_ACCESS_TOKEN=                           # REQUIRED for Meta stdio mode: Access token
META_APP_ID=
META_APP_SECRET=

# LinkedIn API Configuration
LINKEDIN_ACCESS_TOKEN=                       # REQUIRED for LinkedIn stdio mode
LINKEDIN_API_BASE_URL=https://api.linkedin.com
LINKEDIN_API_VERSION=202409
LINKEDIN_RATE_LIMIT_PER_MINUTE=100

# TikTok API Configuration
TIKTOK_ACCESS_TOKEN=                         # REQUIRED for TikTok stdio mode
TIKTOK_ADVERTISER_ID=                        # REQUIRED for TikTok stdio mode
TIKTOK_API_BASE_URL=https://business-api.tiktok.com
TIKTOK_API_VERSION=v1.3
TIKTOK_RATE_LIMIT_PER_MINUTE=100

# CM360 API Configuration
CM360_API_BASE_URL=https://dfareporting.googleapis.com/dfareporting/v5
CM360_SERVICE_ACCOUNT_JSON=                  # REQUIRED for CM360 stdio mode: Service account JSON (base64 or file path)
CM360_SERVICE_ACCOUNT_FILE=                  # Alternative: path to service account JSON file
CM360_RATE_LIMIT_PER_MINUTE=60

# SA360 API Configuration
SA360_CLIENT_ID=                             # REQUIRED for SA360 stdio mode: OAuth2 client ID
SA360_CLIENT_SECRET=                         # REQUIRED for SA360 stdio mode: OAuth2 client secret
SA360_REFRESH_TOKEN=                         # REQUIRED for SA360 stdio mode: OAuth2 refresh token
SA360_LOGIN_CUSTOMER_ID=                     # Optional: Login customer ID
SA360_API_BASE_URL=https://searchads360.googleapis.com/v0
SA360_V2_API_BASE_URL=https://www.googleapis.com/doubleclicksearch/v2
SA360_RATE_LIMIT_PER_MINUTE=100

# Pinterest API Configuration
PINTEREST_ACCESS_TOKEN=                      # REQUIRED for Pinterest stdio mode
PINTEREST_AD_ACCOUNT_ID=                     # Optional: default ad account ID
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REFRESH_TOKEN=
PINTEREST_API_BASE_URL=https://api.pinterest.com
PINTEREST_API_VERSION=v5
PINTEREST_RATE_LIMIT_PER_MINUTE=100
PINTEREST_REPORT_POLL_INTERVAL_MS=5000
PINTEREST_REPORT_MAX_POLL_ATTEMPTS=60
PINTEREST_VIDEO_UPLOAD_POLL_INTERVAL_MS=5000
PINTEREST_VIDEO_UPLOAD_MAX_POLL_ATTEMPTS=60

# Snapchat API Configuration
SNAPCHAT_ACCESS_TOKEN=                       # REQUIRED for Snapchat stdio mode
SNAPCHAT_AD_ACCOUNT_ID=                      # Optional: default ad account ID
SNAPCHAT_ORG_ID=                             # Optional: default organization ID
SNAPCHAT_APP_ID=
SNAPCHAT_APP_SECRET=
SNAPCHAT_REFRESH_TOKEN=
SNAPCHAT_API_BASE_URL=https://adsapi.snapchat.com
SNAPCHAT_API_VERSION=v1
SNAPCHAT_RATE_LIMIT_PER_MINUTE=100
SNAPCHAT_REPORT_POLL_INTERVAL_MS=5000
SNAPCHAT_REPORT_MAX_POLL_ATTEMPTS=60
SNAPCHAT_VIDEO_UPLOAD_POLL_INTERVAL_MS=5000
SNAPCHAT_VIDEO_UPLOAD_MAX_POLL_ATTEMPTS=60

# Amazon DSP API Configuration
AMAZON_DSP_ACCESS_TOKEN=                     # REQUIRED for Amazon DSP stdio mode (LWA bearer)
AMAZON_DSP_PROFILE_ID=                       # Optional: default profile ID
AMAZON_DSP_CLIENT_ID=
AMAZON_DSP_APP_ID=
AMAZON_DSP_APP_SECRET=
AMAZON_DSP_REFRESH_TOKEN=
AMAZON_DSP_API_BASE_URL=https://advertising-api.amazon.com
AMAZON_DSP_API_VERSION=v3
AMAZON_DSP_RATE_LIMIT_PER_MINUTE=100
AMAZON_DSP_REPORT_POLL_INTERVAL_MS=5000
AMAZON_DSP_REPORT_MAX_POLL_ATTEMPTS=60

# Microsoft Advertising API Configuration
MSADS_ACCESS_TOKEN=                          # REQUIRED for MSAds stdio mode
MSADS_DEVELOPER_TOKEN=                       # REQUIRED for MSAds stdio mode
MSADS_CUSTOMER_ID=                           # REQUIRED for MSAds stdio mode
MSADS_ACCOUNT_ID=                            # REQUIRED for MSAds stdio mode
MSADS_CAMPAIGN_API_BASE_URL=https://campaign.api.bingads.microsoft.com/CampaignManagement/v13
MSADS_CUSTOMER_API_BASE_URL=https://clientcenter.api.bingads.microsoft.com/CustomerManagement/v13
MSADS_REPORTING_API_BASE_URL=https://reporting.api.bingads.microsoft.com/Reporting/v13
MSADS_RATE_LIMIT_PER_MINUTE=100
MSADS_REPORT_POLL_INTERVAL_MS=5000
MSADS_REPORT_MAX_POLL_ATTEMPTS=60

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Interaction logging (tool-call + tool-failure persistence)
# gcs: write JSONL to GCS bucket (default in hosted Cloud Run when GCS_BUCKET_NAME is set)
# file: rotating JSONL at ~/.cesteral/interactions/ (self-host default)
# stdout: one Pino line per entry — ship via any stdout log agent
INTERACTION_LOG_MODE=file

# Report CSV spill (large reports → GCS signed URL instead of inline response)
REPORT_SPILL_BUCKET=                         # When unset, spill is disabled
REPORT_SPILL_THRESHOLD_BYTES=16777216        # 16 MB
REPORT_SPILL_THRESHOLD_ROWS=100000
REPORT_SPILL_SIGNED_URL_TTL_SECONDS=3600

# OpenTelemetry Configuration
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cesteral-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
