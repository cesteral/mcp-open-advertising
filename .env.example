# Environment (dev, staging, prod)
NODE_ENV=development

# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=europe-west2

# Cloud Storage Configuration
# Used for persisting data on Cloud Run.
# Uses Application Default Credentials (ADC) — no explicit key needed on Cloud Run.
GCS_BUCKET_NAME=cesteral-storage

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_ISSUER=cesteral-mcp
MCP_RESOURCE_URI=cesteral-services

# MCP Server Configuration
# dbm-mcp (Reporting Server)
DBM_MCP_PORT=3001
DBM_MCP_HOST=0.0.0.0

# dv360-mcp (Management Server)
DV360_MCP_PORT=3002
DV360_MCP_HOST=0.0.0.0

# ttd-mcp (The Trade Desk Server)
TTD_MCP_PORT=3003
TTD_MCP_HOST=0.0.0.0

# gads-mcp (Google Ads Server)
GADS_MCP_PORT=3004
GADS_MCP_HOST=0.0.0.0

# meta-mcp (Meta Ads Server)
META_MCP_PORT=3005
META_MCP_HOST=0.0.0.0

# linkedin-mcp (LinkedIn Ads Server)
LINKEDIN_MCP_PORT=3006
LINKEDIN_MCP_HOST=0.0.0.0

# tiktok-mcp (TikTok Ads Server)
TIKTOK_MCP_PORT=3007
TIKTOK_MCP_HOST=0.0.0.0

# DV360 API Configuration
DV360_API_BASE_URL=https://displayvideo.googleapis.com/v4
DV360_SERVICE_ACCOUNT_JSON=                  # REQUIRED: Service account JSON (base64 or file path)
DV360_RATE_LIMIT_PER_MINUTE=60
SERVICE_ACCOUNT_SECRET_ID=                   # Optional: GCP Secret Manager secret ID

# DV360 MCP Session Management
MCP_SESSION_MODE=auto                        # auto | stateless | stateful
MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000      # 1 hour
MCP_ALLOWED_ORIGINS=*                        # CSV of allowed origins

# MCP Authentication
MCP_AUTH_MODE=none                           # none | jwt | google-headers | ttd-headers | meta-bearer | linkedin-bearer | tiktok-bearer
MCP_AUTH_SECRET_KEY=                         # Required if MCP_AUTH_MODE=jwt (32+ chars)
MCP_LOG_LEVEL=debug                          # debug | info | notice | warning | error

# TTD API Configuration
TTD_PARTNER_ID=                              # REQUIRED for TTD: Partner ID
TTD_API_SECRET=                              # REQUIRED for TTD: API secret

# Google Ads API Configuration
GADS_DEVELOPER_TOKEN=                        # REQUIRED: Google Ads developer token
GADS_CLIENT_ID=                              # REQUIRED: OAuth2 client ID
GADS_CLIENT_SECRET=                          # REQUIRED: OAuth2 client secret
GADS_REFRESH_TOKEN=                          # REQUIRED: OAuth2 refresh token
GADS_LOGIN_CUSTOMER_ID=                      # Optional: Manager account customer ID (no dashes)
GADS_API_BASE_URL=https://googleads.googleapis.com/v23
GADS_RATE_LIMIT_PER_MINUTE=100

# Meta API Configuration
META_ACCESS_TOKEN=                           # REQUIRED for Meta: Access token
META_APP_ID=
META_APP_SECRET=

# LinkedIn API Configuration
LINKEDIN_ACCESS_TOKEN=                       # REQUIRED for LinkedIn stdio mode
LINKEDIN_API_BASE_URL=https://api.linkedin.com
LINKEDIN_API_VERSION=202409
LINKEDIN_RATE_LIMIT_PER_MINUTE=100

# TikTok API Configuration
TIKTOK_ACCESS_TOKEN=                         # REQUIRED for TikTok stdio mode
TIKTOK_ADVERTISER_ID=                        # REQUIRED for TikTok stdio mode
TIKTOK_API_BASE_URL=https://business-api.tiktok.com
TIKTOK_API_VERSION=v1.3
TIKTOK_RATE_LIMIT_PER_MINUTE=100

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# OpenTelemetry Configuration
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cesteral-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
