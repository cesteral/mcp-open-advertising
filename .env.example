# Environment (dev, staging, prod)
NODE_ENV=development

# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# BigQuery Configuration
BIGQUERY_DATASET_ID=bidshifter
BIGQUERY_LOCATION=US

# Cloud Storage Configuration
GCS_BUCKET_NAME=bidshifter-storage

# Redis Configuration (Memorystore)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_ISSUER=bidshifter-mcp
JWT_AUDIENCE=bidshifter-services

# MCP Server Configuration
# dbm-mcp (Reporting Server)
DBM_MCP_PORT=3001
DBM_MCP_HOST=0.0.0.0

# dv360-mcp (Management Server)
DV360_MCP_PORT=3002
DV360_MCP_HOST=0.0.0.0

# DV360 API Configuration
DV360_API_BASE_URL=https://displayvideo.googleapis.com/v4
DV360_SERVICE_ACCOUNT_JSON=                  # REQUIRED: Service account JSON (base64 or file path)
DV360_RATE_LIMIT_PER_MINUTE=60
SERVICE_ACCOUNT_SECRET_ID=                   # Optional: GCP Secret Manager secret ID

# DV360 MCP Session Management
MCP_SESSION_MODE=auto                        # auto | stateless | stateful
MCP_STATEFUL_SESSION_TIMEOUT_MS=3600000      # 1 hour
MCP_ALLOWED_ORIGINS=*                        # CSV of allowed origins

# DV360 MCP Authentication
MCP_AUTH_MODE=none                           # none | jwt | oauth
MCP_AUTH_SECRET_KEY=                         # Required if MCP_AUTH_MODE=jwt (32+ chars)
MCP_LOG_LEVEL=debug                          # debug | info | notice | warning | error

# bidshifter-mcp (Optimization Server)
BIDSHIFTER_MCP_PORT=3003
BIDSHIFTER_MCP_HOST=0.0.0.0

# Google Ads API Configuration (Future)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Meta API Configuration (Future)
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# Pub/Sub Configuration
PUBSUB_TOPIC_AUDIT=bidshifter-audit
PUBSUB_TOPIC_NOTIFICATIONS=bidshifter-notifications

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# OpenTelemetry Configuration
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bidshifter-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optimization Configuration
OPTIMIZATION_STRATEGY=moderate
OPTIMIZATION_MAX_ADJUSTMENT_PERCENT=2
OPTIMIZATION_MIN_IMPRESSIONS=1000
PACING_TARGET_PERCENT=95
PACING_TOLERANCE_PERCENT=5

# Cloud Scheduler Configuration
DATA_SYNC_CRON=0 */4 * * *
OPTIMIZATION_SCAN_CRON=0 */4 * * *
ADJUSTMENT_EXECUTOR_CRON=*/30 * * * *
OUTCOME_TRACKER_CRON=0 0 * * *

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
