{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "name": "wms/mcp-ts-quickstart-template",
  "description": "Template for Model Context Protocol (MCP) servers with TypeScript",
  "repository": {
    "url": "https://github.com/wms/mcp-ts-quickstart-template",
    "source": "github"
  },
  "version": "0.0.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "mcp-ts-quickstart-template",
      "runtimeHint": "node",
      "version": "0.0.0",
      "packageArguments": [
        {
          "type": "positional",
          "value": "run"
        },
        {
          "type": "positional",
          "value": "start:stdio"
        }
      ],
      "environmentVariables": [
        {
          "name": "MCP_LOG_LEVEL",
          "description": "Sets the minimum log level for output (e.g., 'debug', 'info', 'warn').",
          "format": "string",
          "isRequired": false,
          "default": "debug"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "mcp-ts-quickstart-template",
      "runtimeHint": "node",
      "version": "0.0.0",
      "packageArguments": [
        {
          "type": "positional",
          "value": "run"
        },
        {
          "type": "positional",
          "value": "start:http"
        }
      ],
      "environmentVariables": [
        {
          "name": "MCP_HTTP_HOST",
          "description": "Hostname that the HTTP transport should bind to.",
          "format": "string",
          "isRequired": false,
          "default": "127.0.0.1"
        },
        {
          "name": "MCP_HTTP_PORT",
          "description": "Port number for the HTTP transport.",
          "format": "string",
          "isRequired": false,
          "default": "3010"
        },
        {
          "name": "MCP_HTTP_ENDPOINT_PATH",
          "description": "Endpoint path exposed by the HTTP transport.",
          "format": "string",
          "isRequired": false,
          "default": "/mcp"
        },
        {
          "name": "MCP_AUTH_MODE",
          "description": "Authentication mode to use: 'none', 'jwt', or 'oauth'.",
          "format": "string",
          "isRequired": false,
          "default": "none"
        },
        {
          "name": "MCP_LOG_LEVEL",
          "description": "Sets the minimum log level for output (e.g., 'debug', 'info', 'warn').",
          "format": "string",
          "isRequired": false,
          "default": "debug"
        }
      ],
      "transport": {
        "type": "streamable-http",
        "url": "http://127.0.0.1:3010/mcp"
      }
    }
  ]
}
